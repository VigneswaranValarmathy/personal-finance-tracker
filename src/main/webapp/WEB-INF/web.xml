<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <welcome-file-list>
        <welcome-file>pages/login.html</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.finance.servlets.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.finance.servlets.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddTransactionServlet</servlet-name>
        <servlet-class>com.finance.servlets.AddTransactionServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddTransactionServlet</servlet-name>
        <url-pattern>/addTransaction</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetTransactionServlet</servlet-name>
        <servlet-class>com.finance.servlets.GetTransactionServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>GetTransactionServlet</servlet-name>
        <url-pattern>/getTransaction</url-pattern>
    </servlet-mapping>

	<servlet>
		<servlet-name>DeleteTransactionServlet</servlet-name>
		<servlet-class>com.finance.servlets.DeleteTransactionServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>DeleteTransactionServlet</servlet-name>
		<url-pattern>/deleteTransaction</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>EditTransactionServlet</servlet-name>
		<servlet-class>com.finance.servlets.EditTransactionServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	<servlet-name>EditTransactionServlet</servlet-name>
	<url-pattern>/editTransaction</url-pattern>
	</servlet-mapping>

</web-app>